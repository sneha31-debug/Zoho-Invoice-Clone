# Zoho Invoice Clone - Production Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=production
JWT_SECRET=your_long_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# Database Configuration
# Managed MySQL Connection (e.g. Aiven, Railway, PlanetScale)
DATABASE_URL=mysql://user:password@host:port/dbname

# SMTP Configuration (For sending invoice emails)
# Support for SendGrid, Mailgun, or Gmail App Password
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Razorpay Configuration (For payments)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Frontend Configuration (Not usually needed in unified mode, but for reference)
VITE_API_BASE=/api/v1
